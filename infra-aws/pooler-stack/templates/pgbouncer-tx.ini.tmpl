; PgBouncer — modo TRANSACTION (CLOUD)
; Template: __RDS_ENDPOINT__ e __POOL_SIZE__ substituídos pelo orquestrador (configs.py cloud).
; MD5 client-side (paridade com PgCat / issue #255). RDS com password_encryption=md5.

[databases]
tcc = host=__RDS_ENDPOINT__ port=5432 dbname=tcc

[pgbouncer]
listen_addr = 0.0.0.0
listen_port = 6432
auth_type = md5
auth_file = /etc/pgbouncer/userlist.txt
admin_users = tcc
stats_users = tcc

; --- Pooling ---
pool_mode = transaction
max_prepared_statements = 100

; --- Limites ---
max_client_conn = 1100
default_pool_size = __POOL_SIZE__
reserve_pool_size = 5
reserve_pool_timeout = 3
max_db_connections = 0
max_user_connections = 0

; --- Timeouts ---
server_idle_timeout = 600
server_lifetime = 3600
query_wait_timeout = 120
client_idle_timeout = 0

; --- Compatibilidade ---
ignore_startup_parameters = extra_float_digits

; --- Logging ---
log_connections = 0
log_disconnections = 0
log_pooler_errors = 1
